<view class="app-page home-page">
  <view class="home-navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="home-navbar-row">
      <view class="location-pill navbar-location-pill" bindtap="handleLocationTap">
        <text class="location-text">{{locationText}}</text>
        <text class="location-chevron">›</text>
      </view>
    </view>
  </view>

  <view class="hero-card card-shadow">
    <view class="tab-row">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab-item {{activeTab === item.key ? 'tab-item-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="handleTabChange"
      >
        {{item.label}}
      </view>
    </view>
  </view>

  <view wx:if="{{locationTip}}" class="notice-card card-shadow">
    <view class="notice-text">{{locationTip}}</view>
    <view wx:if="{{locationDenied}}" class="notice-action" bindtap="handleManualLocationTip">
      开启定位
    </view>
  </view>

  <loading-view loading="{{initialLoading}}" text="课程加载中..." />

  <view wx:if="{{!initialLoading && courseList.length}}" class="course-list">
    <view
      wx:for="{{courseList}}"
      wx:key="id"
      class="course-card card-shadow"
      data-id="{{item.id}}"
      bindtap="handleCourseTap"
    >
      <view class="cover-wrap">
        <image class="course-cover" src="{{item.cover}}" mode="aspectFill"></image>
        <view wx:if="{{item.soonGroup}}" class="group-tag">即将成团</view>
      </view>

      <view class="course-content">
        <view class="course-title-row">
          <view class="course-title">{{item.title}}</view>
          <view wx:if="{{activeTab === 'all'}}" class="distance-text">{{item.distanceText}}</view>
        </view>

        <view class="course-meta">{{item.timeText}}</view>
        <view class="course-meta">{{item.locationText}}</view>
        <view wx:if="{{item.showActiveGroupCountdown}}" class="countdown-pill">
          <view class="countdown-dot"></view>
          <view class="countdown-text">{{item.activeGroup.expireTimeText}}</view>
        </view>

        <view class="course-footer">
          <view class="price-group">
            <view class="group-price">¥{{item.groupPriceText}}</view>
            <view class="original-price">¥{{item.originalPriceText}}</view>
          </view>
          <view class="footer-status">
            <view wx:if="{{item.showSuccessBadge}}" class="success-text">已拼团成功</view>
            <view wx:if="{{item.showJoinedCount}}" class="joined-text">已拼 {{item.displayJoinedCount}} 人</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <empty-state
    wx:if="{{!initialLoading && !courseList.length}}"
    title="暂无可展示课程"
    desc="下拉刷新后再试，或稍后切换筛选条件查看。"
  />

  <view wx:if="{{!initialLoading && courseList.length}}" class="list-footer">
    <block wx:if="{{loading}}">
      <view class="footer-text">加载中...</view>
    </block>
    <block wx:elif="{{!hasMore}}">
      <view class="footer-text">没有更多课程了</view>
    </block>
    <block wx:else>
      <view class="footer-text">上拉加载更多</view>
    </block>
  </view>
</view>
