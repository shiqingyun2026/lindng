<view class="app-page mine-page">
  <view class="profile-card card-shadow">
    <view class="profile-main">
      <view class="avatar-box">
        <view class="avatar-placeholder">
          <image class="avatar-placeholder-icon" src="/assets/ant-icons/user-white.svg" mode="aspectFit" />
        </view>
      </view>
      <view class="profile-info">
        <view class="profile-name">{{userInfo ? userInfo.nickName : '未登录用户'}}</view>
      </view>
    </view>

    <button
      wx:if="{{!userInfo}}"
      class="primary-button login-button"
      bindtap="handleLogin"
      loading="{{loginLoading}}"
    >
      去登录
    </button>

    <button
      wx:if="{{userInfo}}"
      class="primary-button secondary-button logout-button"
      bindtap="handleLogout"
    >
      退出登录
    </button>
  </view>

  <view class="menu-card card-shadow">
    <view
      wx:for="{{menuList}}"
      wx:key="key"
      class="menu-item"
      data-key="{{item.key}}"
      bindtap="handleMenuTap"
    >
      <view>
        <view class="menu-title">{{item.title}}</view>
        <view class="menu-desc">{{item.desc}}</view>
      </view>
      <image class="menu-arrow" src="/assets/ant-icons/arrow-right-muted.svg" mode="aspectFit" />
    </view>
  </view>

  <base-modal
    visible="{{showServiceModal}}"
    title="联系客服"
    confirmText="我知道了"
    cancelText="关闭"
    bindclose="handleCloseService"
    bindcancel="handleCloseService"
    bindconfirm="handleConfirmService"
  >
    <view class="service-modal-content">
      <image class="service-qrcode" src="{{serviceQrCode}}" mode="aspectFit"></image>
      <view class="service-tip">请使用微信扫码联系专属客服</view>
    </view>
  </base-modal>

  <login-sheet
    visible="{{showLoginModal}}"
    loading="{{loginLoading}}"
    agreementChecked="{{loginAgreementChecked}}"
    bind:close="handleCloseLoginModal"
    bind:confirm="handleConfirmLogin"
    bind:toggleagreement="handleToggleLoginAgreement"
    bind:openagreement="handleOpenAgreement"
    bind:openprivacy="handleOpenPrivacy"
  />
</view>
