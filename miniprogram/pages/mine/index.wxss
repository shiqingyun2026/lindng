.mine-page {
  padding-bottom: 24rpx;
}

.profile-card,
.menu-card {
  margin-bottom: 24rpx;
  padding: 40rpx 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
}

.menu-card {
  padding-top: 28rpx;
  padding-bottom: 28rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-card-guest {
  min-height: 156rpx;
}

.avatar-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 0%, #69a7ff 100%);
}

.avatar-box-guest {
  width: 134rpx;
  height: 134rpx;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.avatar-placeholder-icon {
  width: 44rpx;
  height: 44rpx;
}

.avatar-box-guest .avatar-placeholder-icon {
  width: 53rpx;
  height: 53rpx;
}

.avatar-placeholder {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2329;
}

.profile-name-guest {
  font-size: 40rpx;
}

.logout-button {
  margin-top: 28rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 112rpx;
  padding: 32rpx 4rpx;
}

.menu-item + .menu-item {
  border-top: 2rpx solid #f0f2f5;
}

.menu-title {
  font-size: 36rpx;
  font-weight: 400;
  color: #1f2329;
}

.menu-arrow {
  color: #1f2329;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1;
  flex-shrink: 0;
}

.service-modal-content {
  padding-top: 8rpx;
  text-align: center;
}

.service-qrcode {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto;
  border-radius: 20rpx;
  background: #eef2f7;
}

.service-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #5f6b7a;
}

.login-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(0, 0, 0, 0.4);
}

.login-sheet {
  position: relative;
  width: 100%;
  max-width: 750rpx;
  min-height: 0;
  padding: 32rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -16rpx 48rpx rgba(0, 0, 0, 0.18);
}

.login-sheet-title {
  margin-top: 28rpx;
  padding: 0 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  color: #1f2329;
  line-height: 1.4;
}

.login-sheet-icon {
  width: 128rpx;
  height: 128rpx;
  margin: 24rpx auto 0;
  border-radius: 50%;
  background: #dbeafe;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-sheet-bolt {
  width: 56rpx;
  height: 56rpx;
}

.login-sheet-button-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 36rpx;
}

.login-sheet-button,
.login-sheet-secondary-button {
  flex: 1;
  height: 96rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 96rpx;
}

.login-sheet-button {
  background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 100%);
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.24);
  font-weight: 500;
}

.login-sheet-secondary-button {
  padding: 0;
  border: 2rpx solid #dbe3f0;
  background: #ffffff;
  color: #6b7280;
  font-weight: 500;
}

.login-sheet-secondary-button::after {
  border: none;
}

.login-sheet-agreement-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 0 28rpx;
}

.login-sheet-check-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 4rpx;
}

.login-sheet-check {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
  border: 2rpx solid #cbd5e1;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-sheet-check-active {
  background: #3b82f6;
  border-color: #3b82f6;
}

.login-sheet-check-mark {
  width: 16rpx;
  height: 16rpx;
}

.login-sheet-agreement {
  max-width: 480rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #6b7280;
  text-align: center;
}

.login-sheet-link {
  color: #3b82f6;
  font-weight: 500;
}
