.location-search-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fbfcff 0%, #f3f6fb 100%);
}

.page-header {
  padding-bottom: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.05);
}

.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.header-back,
.header-space {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
}

.header-back-icon {
  width: 28rpx;
  height: 28rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 24rpx;
  padding: 14rpx 18rpx;
  border-radius: 28rpx;
  background: #ffffff;
}

.city-pill {
  flex-shrink: 0;
  padding-right: 18rpx;
  border-right: 1rpx solid #edf1f7;
  color: #1f2329;
  font-size: 26rpx;
  font-weight: 600;
}

.search-box {
  display: flex;
  flex: 1;
  align-items: center;
  min-width: 0;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #f5f7fb;
}

.search-icon,
.clear-btn {
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-icon,
.clear-icon {
  width: 28rpx;
  height: 28rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  color: #1f2329;
  font-size: 26rpx;
}

.page-body {
  padding: 20rpx 24rpx 48rpx;
}

.current-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #f1f6ff 0%, #edf4ff 100%);
}

.current-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #2d7fff 0%, #156cff 100%);
  color: #ffffff;
}

.current-icon-image {
  width: 34rpx;
  height: 34rpx;
}

.current-content {
  flex: 1;
  min-width: 0;
}

.current-label {
  color: #2d7fff;
  font-size: 22rpx;
  font-weight: 600;
}

.current-name {
  margin-top: 6rpx;
  color: #1f2329;
  font-size: 32rpx;
  font-weight: 700;
}

.current-address {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.6;
}

.current-action {
  flex-shrink: 0;
  color: #2d7fff;
  font-size: 24rpx;
  font-weight: 700;
}

.state-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 140rpx 40rpx 80rpx;
  text-align: center;
}

.state-spinner,
.state-empty-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  border-radius: 36rpx;
  background: radial-gradient(circle, rgba(45, 127, 255, 0.16) 0%, rgba(45, 127, 255, 0.06) 70%, rgba(45, 127, 255, 0) 100%);
  box-shadow: 0 22rpx 56rpx rgba(45, 127, 255, 0.08);
}

.state-spinner-icon,
.state-empty-icon-image {
  width: 72rpx;
  height: 72rpx;
}

.state-spinner-icon {
  animation: ant-icon-spin 1s linear infinite;
}

.state-title {
  margin-top: 34rpx;
  color: #1f2329;
  font-size: 40rpx;
  font-weight: 700;
}

.state-desc {
  margin-top: 18rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.8;
}

.result-section {
  margin-top: 20rpx;
}

.result-header {
  padding: 8rpx 4rpx 18rpx;
}

.result-title {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 700;
}

.result-subtitle {
  margin-top: 8rpx;
  color: #8f96a3;
  font-size: 22rpx;
}

.result-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 18rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
}

.result-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #edf4ff;
}

.result-icon-image {
  width: 30rpx;
  height: 30rpx;
}

.result-icon.warm {
  color: #ff7a45;
  background: #fff2eb;
}

.result-icon.violet {
  color: #8b5cf6;
  background: #f4eeff;
}

.result-icon.green {
  color: #10b981;
  background: #ebfbf5;
}

.result-content {
  flex: 1;
  min-width: 0;
}

.result-name {
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 700;
}

.result-address {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.6;
}

.result-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.distance-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #2d7fff;
  font-size: 22rpx;
  font-weight: 700;
}

.result-arrow {
  width: 24rpx;
  height: 24rpx;
  flex-shrink: 0;
}

.result-footer {
  padding: 28rpx 0 6rpx;
  text-align: center;
}

.footer-line {
  width: 100%;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(205, 213, 224, 0) 0%, rgba(205, 213, 224, 0.9) 50%, rgba(205, 213, 224, 0) 100%);
}

.footer-end {
  margin-top: 12rpx;
  color: #b6bdc8;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.footer-text {
  margin-top: 8rpx;
  color: #b6bdc8;
  font-size: 22rpx;
}

@keyframes ant-icon-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}
