.agreement-content-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 28rpx 24rpx 32rpx;
  background: #f7f8fa;
  box-sizing: border-box;
}

.agreement-content-header {
  padding: 8rpx 4rpx 24rpx;
}

.agreement-content-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2329;
}

.agreement-content-subtitle {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6a7787;
}

.agreement-content-body {
  flex: 1;
  min-height: 0;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 2rpx solid #e8edf3;
  box-sizing: border-box;
}

.agreement-content-rich-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #1f2329;
}
