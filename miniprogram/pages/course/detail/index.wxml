<view class="detail-page">
  <loading-view loading="{{loading}}" text="详情加载中..." />

  <scroll-view wx:if="{{!loading && courseDetail}}" class="detail-scroll" scroll-y>
    <swiper class="hero-swiper" indicator-dots autoplay circular>
      <swiper-item wx:for="{{courseDetail.images}}" wx:key="*this">
        <image class="hero-image" src="{{item}}" mode="aspectFill"></image>
      </swiper-item>
    </swiper>

    <view class="detail-content">
      <view class="page-section card-shadow">
        <view class="title-row">
          <view class="course-title">{{courseDetail.title}}</view>
          <view wx:if="{{hasActiveGroup}}" class="group-chip">{{groupTargetCount}}人成团</view>
        </view>

        <view class="price-row">
          <view class="group-price">¥{{courseDetail.groupPriceText}}</view>
          <view class="original-price">¥{{courseDetail.originalPriceText}}</view>
          <view wx:if="{{showJoinedCount}}" class="joined-chip">已拼 {{displayJoinedCount}} 人</view>
        </view>

        <view class="info-list">
          <view class="info-item">
            <view class="info-label">上课时间</view>
            <view class="info-value">{{courseDetail.timeText}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">上课地点</view>
            <view class="info-value">{{courseDetail.locationText}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">适用年龄</view>
            <view class="info-value">{{courseDetail.ageRange}}</view>
          </view>
        </view>
      </view>

      <view class="page-section card-shadow">
        <view class="section-title">课程介绍</view>
        <rich-text class="rich-text" nodes="{{courseDetail.descriptionHtml || courseDetail.descriptionNodes}}"></rich-text>
      </view>

      <view class="page-section card-shadow">
        <view class="section-title">拼团规则</view>
        <rich-text class="rich-text" nodes="{{courseDetail.groupRuleNodes}}"></rich-text>
      </view>

      <view class="page-section card-shadow">
        <view class="section-title">教练信息</view>
        <view class="coach-name">{{courseDetail.coach.name}}</view>
        <view class="coach-intro">{{courseDetail.coach.intro}}</view>
        <view class="certificate-list">
          <image
            wx:for="{{courseDetail.coach.certificates}}"
            wx:key="*this"
            class="certificate-image"
            src="{{item}}"
            mode="aspectFill"
            data-url="{{item}}"
            bindtap="handlePreviewCertificate"
          ></image>
        </view>
      </view>

      <view class="page-section card-shadow insurance-card">
        <view class="section-title">保险说明</view>
        <view class="section-desc insurance-text">{{courseDetail.insuranceText}}</view>
      </view>

      <view class="page-section card-shadow">
        <view class="section-title">当前拼团状态</view>
        <view wx:if="{{courseGroupList.length}}" class="group-panel">
          <view wx:for="{{courseGroupList}}" wx:key="groupId" class="group-item-card">
            <view class="group-item-header">
              <view class="group-item-title">第{{item.index}}个团</view>
              <view class="group-item-status group-item-status-{{item.statusClass}}">{{item.statusText}}</view>
            </view>

            <view class="group-progress-row">
              <view class="group-progress-text">当前进度 {{item.progressText}}</view>
              <view class="group-progress-caption">{{item.caption}}</view>
            </view>
            <view class="progress-track">
              <view class="progress-bar" style="width: {{item.progressPercent}};"></view>
            </view>
          </view>
        </view>

        <view wx:else class="group-empty">
          <view class="section-desc">{{emptyGroupText}}</view>
        </view>
      </view>

      <view class="bottom-space"></view>
    </view>
  </scroll-view>

  <view wx:if="{{!loading && courseDetail}}" class="bottom-bar">
    <view class="service-entry" bindtap="handleOpenService">
      <view class="service-icon">客</view>
      <view class="service-text">客服</view>
    </view>
    <button
      class="primary-button bottom-action"
      bindtap="handleGoPayment"
      loading="{{creatingOrder}}"
      disabled="{{creatingOrder || actionButtonDisabled}}"
    >
      {{actionButtonText}}
    </button>
  </view>

  <base-modal
    wx:if="{{courseDetail}}"
    visible="{{showServiceModal}}"
    title="联系客服"
    confirmText="我知道了"
    cancelText="关闭"
    bindclose="handleCloseService"
    bindcancel="handleCloseService"
    bindconfirm="handleConfirmService"
  >
    <view class="service-modal-content">
      <image class="service-qrcode" src="{{courseDetail.serviceQrCode}}" mode="aspectFit"></image>
      <view class="service-tip">请使用微信扫码联系专属客服</view>
    </view>
  </base-modal>

  <view wx:if="{{showLoginModal}}" class="login-sheet-mask" bindtap="handleCloseLoginModal">
    <view class="login-sheet" catchtap="noop">
      <view class="login-sheet-icon">
        <text class="login-sheet-bolt">⚡</text>
      </view>
      <view class="login-sheet-title">完成登录即可参团</view>
      <view class="login-sheet-button-row">
        <button class="login-sheet-secondary-button" bindtap="handleCloseLoginModal" disabled="{{loginLoading}}">
          稍后登录
        </button>
        <button class="primary-button login-sheet-button" bindtap="handleConfirmLogin" loading="{{loginLoading}}">
          授权并登录
        </button>
      </view>
      <view class="login-sheet-agreement-row">
        <view class="login-sheet-check-wrap" bindtap="handleToggleLoginAgreement">
          <view class="login-sheet-check {{loginAgreementChecked ? 'login-sheet-check-active' : ''}}">
            <text wx:if="{{loginAgreementChecked}}" class="login-sheet-check-mark">✓</text>
          </view>
        </view>
        <view class="login-sheet-agreement">
          <text>我已阅读并同意</text>
          <text class="login-sheet-link" bindtap="handleOpenAgreement">用户协议</text>
          <text>和</text>
          <text class="login-sheet-link" bindtap="handleOpenPrivacy">隐私政策</text>
        </view>
      </view>
    </view>
  </view>
</view>
