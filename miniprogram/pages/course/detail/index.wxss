.detail-page {
  position: relative;
  min-height: 100vh;
  background: #f7f8fa;
}

.detail-scroll {
  height: 100vh;
}

.hero-swiper {
  width: 100%;
  height: 420rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.detail-content {
  margin-top: -20rpx;
  padding: 0 24rpx 0;
}

.title-row,
.price-row,
.group-progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.course-title {
  flex: 1;
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2329;
  line-height: 1.5;
}

.group-chip,
.joined-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.group-chip {
  background: #eef5ff;
  color: #1677ff;
}

.joined-chip {
  background: #fff3e8;
  color: #ff7a00;
}

.price-row {
  align-items: flex-end;
  margin-top: 24rpx;
}

.group-price {
  color: #ff7a00;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.original-price {
  flex: 1;
  padding-bottom: 6rpx;
  color: #b6bdc8;
  font-size: 24rpx;
  text-decoration: line-through;
}

.info-list {
  margin-top: 28rpx;
}

.info-item + .info-item {
  margin-top: 18rpx;
}

.info-label {
  font-size: 24rpx;
  color: #8f96a3;
}

.info-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #1f2329;
  line-height: 1.7;
}

.rich-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #3c4655;
  line-height: 1.8;
}

.coach-name {
  margin-top: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

.coach-intro {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #5f6b7a;
}

.certificate-list {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.certificate-image {
  width: 220rpx;
  height: 146rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #eef2f7;
}

.insurance-card {
  background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
}

.insurance-text {
  margin-top: 16rpx;
  line-height: 1.8;
}

.login-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(0, 0, 0, 0.4);
}

.login-sheet {
  position: relative;
  width: 100%;
  max-width: 750rpx;
  min-height: 0;
  padding: 32rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -16rpx 48rpx rgba(0, 0, 0, 0.18);
}

.login-sheet-title {
  margin-top: 28rpx;
  padding: 0 32rpx;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  color: #1f2329;
  line-height: 1.4;
}

.login-sheet-icon {
  width: 128rpx;
  height: 128rpx;
  margin: 24rpx auto 0;
  border-radius: 50%;
  background: #dbeafe;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-sheet-bolt {
  font-size: 56rpx;
  line-height: 1;
  color: #3b82f6;
}

.login-sheet-button-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 36rpx;
}

.login-sheet-button,
.login-sheet-secondary-button {
  flex: 1;
  height: 96rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 96rpx;
}

.login-sheet-button {
  background: linear-gradient(90deg, #3b82f6 0%, #60a5fa 100%);
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.24);
  font-weight: 500;
}

.login-sheet-secondary-button {
  padding: 0;
  border: 2rpx solid #dbe3f0;
  background: #ffffff;
  color: #6b7280;
  font-weight: 500;
}

.login-sheet-secondary-button::after {
  border: none;
}

.login-sheet-agreement-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 0 28rpx;
}

.login-sheet-check-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 4rpx;
}

.login-sheet-check {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
  border: 2rpx solid #cbd5e1;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-sheet-check-active {
  background: #3b82f6;
  border-color: #3b82f6;
}

.login-sheet-check-mark {
  font-size: 16rpx;
  line-height: 1;
  color: #ffffff;
}

.login-sheet-agreement {
  max-width: 480rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #6b7280;
  text-align: center;
}

.login-sheet-link {
  color: #3b82f6;
  font-weight: 500;
}

.group-panel,
.group-empty {
  margin-top: 20rpx;
}

.group-panel {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.group-item-card {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #f8fafc;
  border: 1rpx solid #e7ecf3;
}

.group-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.group-item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
}

.group-item-status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.group-item-status-ongoing {
  background: #eef5ff;
  color: #1677ff;
}

.group-item-status-success {
  background: #ecfbf3;
  color: #18a058;
}

.group-item-status-failed {
  background: #f4f6f8;
  color: #8f96a3;
}

.group-deadline-card {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid transparent;
}

.group-deadline-normal {
  background: linear-gradient(180deg, #f6faff 0%, #eef5ff 100%);
  border-color: rgba(22, 119, 255, 0.12);
}

.group-deadline-warning {
  background: linear-gradient(180deg, #fff8ef 0%, #fff1df 100%);
  border-color: rgba(255, 122, 0, 0.16);
}

.group-deadline-urgent {
  background: linear-gradient(180deg, #fff4f0 0%, #ffe7df 100%);
  border-color: rgba(255, 122, 0, 0.2);
}

.group-deadline-main,
.group-progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.group-deadline-label {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.group-deadline-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff7a00;
  box-shadow: 0 0 0 6rpx rgba(255, 122, 0, 0.1);
}

.group-deadline-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #7c5b31;
}

.group-deadline-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2329;
}

.group-deadline-hint {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #8a6d46;
}

.group-progress-row {
  margin-top: 24rpx;
}

.group-progress-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2329;
}

.group-progress-caption {
  font-size: 22rpx;
  color: #8f96a3;
}

.progress-track {
  width: 100%;
  height: 16rpx;
  margin-top: 20rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eef2f7;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1677ff 0%, #69a7ff 100%);
}

.member-list {
  display: flex;
  margin-top: 24rpx;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  margin-right: -12rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #eef2f7;
}

.bottom-space {
  height: 160rpx;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(31, 35, 41, 0.06);
}

.service-entry {
  width: 104rpx;
  text-align: center;
}

.service-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #eef5ff;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 700;
}

.service-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5f6b7a;
}

.bottom-action {
  flex: 1;
}

.service-modal-content {
  padding-top: 8rpx;
  text-align: center;
}

.service-qrcode {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto;
  border-radius: 20rpx;
  background: #eef2f7;
}

.service-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #5f6b7a;
}
