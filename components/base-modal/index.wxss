.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.45);
}

.modal-panel {
  width: 100%;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2329;
}

.modal-body {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #5f6b7a;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
}

.modal-button {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border-radius: 999rpx;
  border: none;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 600;
}

.modal-button::after {
  border: none;
}

.cancel-button {
  background: #f2f3f5;
  color: #5f6b7a;
}

.confirm-button {
  background: #1677ff;
  color: #ffffff;
}
