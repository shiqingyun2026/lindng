<view wx:if="{{visible}}" class="modal-mask" bindtap="handleMaskTap">
  <view class="modal-panel" catchtap="noop">
    <view class="modal-title">{{title}}</view>
    <view class="modal-body">
      <slot></slot>
    </view>
    <view class="modal-footer">
      <button wx:if="{{showCancel}}" class="modal-button cancel-button" bindtap="handleCancel">
        {{cancelText}}
      </button>
      <button class="modal-button confirm-button" bindtap="handleConfirm">
        {{confirmText}}
      </button>
    </view>
  </view>
</view>
