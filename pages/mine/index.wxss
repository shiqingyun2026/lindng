.mine-page {
  padding-bottom: 24rpx;
}

.profile-card,
.menu-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
}

.profile-main {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 0%, #69a7ff 100%);
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2329;
}

.profile-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8f96a3;
}

.login-button {
  margin-top: 28rpx;
}

.logout-button {
  margin-top: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 28rpx 0;
}

.menu-item + .menu-item {
  border-top: 2rpx solid #eef2f7;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

.menu-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8f96a3;
}

.menu-arrow {
  color: #b6bdc8;
  font-size: 28rpx;
}

.service-modal-content {
  padding-top: 8rpx;
  text-align: center;
}

.service-qrcode {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto;
  border-radius: 20rpx;
  background: #eef2f7;
}

.service-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #5f6b7a;
}
