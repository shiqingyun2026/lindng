.payment-page {
  min-height: 100vh;
  background: #f7f8fa;
}

.payment-scroll {
  height: 100vh;
}

.payment-content {
  padding: 24rpx;
}

.order-title {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #1f2329;
}

.order-item {
  margin-top: 20rpx;
}

.order-label {
  font-size: 24rpx;
  color: #8f96a3;
}

.order-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #1f2329;
}

.price-item {
  padding-top: 12rpx;
  border-top: 2rpx solid #eef2f7;
}

.payment-price {
  margin-top: 8rpx;
  color: #ff7a00;
  font-size: 40rpx;
  font-weight: 700;
}

.rich-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #3c4655;
  line-height: 1.8;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.agreement-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: #3c4655;
}

.bottom-placeholder {
  height: 160rpx;
}

.payment-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(31, 35, 41, 0.06);
}

.payment-button {
  width: 100%;
}

.mock-fail-button {
  height: 72rpx;
  margin-top: 12rpx;
  border: none;
  background: transparent;
  color: #8f96a3;
  font-size: 24rpx;
  line-height: 72rpx;
}

.mock-fail-button::after {
  border: none;
}
