.agreement-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  background: #f7f8fa;
}

.agreement-header {
  padding: 8rpx 8rpx 24rpx;
}

.agreement-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2329;
}

.agreement-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #5f6b7a;
}

.agreement-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.agreement-tab {
  flex: 1;
  padding: 20rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #5f6b7a;
  text-align: center;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
}

.agreement-tab-active {
  background: #1677ff;
  color: #ffffff;
  font-weight: 600;
}

.agreement-content {
  flex: 1;
  min-height: 0;
  padding: 32rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(31, 35, 41, 0.06);
}

.agreement-rich-text {
  color: #1f2329;
  font-size: 28rpx;
  line-height: 1.8;
}

.rich-block {
  margin-bottom: 32rpx;
}

.rich-title {
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2329;
}

.rich-paragraph {
  margin-bottom: 16rpx;
  color: #3c4655;
}

.rich-list {
  padding-left: 32rpx;
}

.rich-list-item {
  margin-bottom: 16rpx;
  color: #3c4655;
}

.agreement-footer {
  padding-top: 24rpx;
}

.agreement-checkbox {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 35, 41, 0.04);
}

.agreement-checkbox checkbox {
  transform: scale(0.9);
  transform-origin: left top;
}

.agreement-checkbox-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.7;
  color: #3c4655;
}

.agreement-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.footer-button {
  flex: 1;
  height: 88rpx;
  border-radius: 999rpx;
  border: none;
  font-size: 30rpx;
  line-height: 88rpx;
}

.footer-button::after {
  border: none;
}

.reject-button {
  background: #edf1f5;
  color: #5f6b7a;
}

.agree-button {
  background: #1677ff;
  color: #ffffff;
}
