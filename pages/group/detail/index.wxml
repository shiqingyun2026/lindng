<view class="group-detail-page">
  <loading-view loading="{{loading}}" text="拼团详情加载中..." />

  <scroll-view wx:if="{{!loading && groupDetail}}" class="group-scroll" scroll-y>
    <view class="app-page detail-content">
      <view class="status-tag {{statusClassName}}">{{statusText}}</view>

      <view class="page-section card-shadow">
        <view class="title-row">
          <view class="course-title">{{groupDetail.courseInfo.title}}</view>
          <view class="group-chip">{{groupDetail.courseInfo.targetCount}}人成团</view>
        </view>

        <view class="price-row">
          <view class="group-price">¥{{groupDetail.courseInfo.groupPriceText}}</view>
          <view class="original-price">¥{{groupDetail.courseInfo.originalPriceText}}</view>
          <view class="joined-chip">已拼 {{groupDetail.currentCount}} 人</view>
        </view>

        <view class="info-list">
          <view class="info-item">
            <view class="info-label">上课时间</view>
            <view class="info-value">{{groupDetail.courseInfo.timeText}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">上课地点</view>
            <view class="info-value">{{groupDetail.courseInfo.locationText}}</view>
          </view>
          <view class="info-item">
            <view class="info-label">适用年龄</view>
            <view class="info-value">{{groupDetail.courseInfo.ageRange}}</view>
          </view>
        </view>
      </view>

      <view class="page-section card-shadow">
        <view class="section-title">拼团进度</view>
        <view class="progress-header">
          <view class="progress-text">{{groupDetail.progressText}}</view>
          <view wx:if="{{groupDetail.status === 'ongoing'}}" class="remaining-text">
            {{groupDetail.expireTimeText}}
          </view>
        </view>
        <view class="progress-track">
          <view class="progress-bar" style="width: {{groupDetail.progressPercent}};"></view>
        </view>
        <view wx:if="{{groupDetail.status !== 'ongoing'}}" class="section-desc progress-desc">
          {{groupDetail.refundDesc}}
        </view>
      </view>

      <view class="page-section card-shadow">
        <view class="section-title">参团成员</view>
        <scroll-view class="member-scroll" scroll-x enable-flex>
          <view class="member-list">
            <view wx:for="{{groupDetail.members}}" wx:key="nickName" class="member-item">
              <image class="member-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
              <view class="member-name">{{item.nickName}}</view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="bottom-space"></view>
    </view>
  </scroll-view>

  <view wx:if="{{!loading && groupDetail}}" class="bottom-bar">
    <block wx:if="{{groupDetail.status === 'ongoing' && groupDetail.userJoined}}">
      <button class="primary-button bottom-button" open-type="share">邀请好友</button>
    </block>

    <block wx:elif="{{groupDetail.status === 'ongoing' && !groupDetail.userJoined}}">
      <button class="primary-button bottom-button" bindtap="handleJoinGroup">立即参团</button>
    </block>

    <block wx:else>
      <view class="bottom-status-text">
        {{groupDetail.status === 'success' ? '已成团，等待上课' : '拼团失败，已退款'}}
      </view>
    </block>
  </view>
</view>
