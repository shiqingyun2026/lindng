.group-detail-page {
  min-height: 100vh;
  background: #f7f8fa;
}

.group-scroll {
  height: 100vh;
}

.detail-content {
  padding-bottom: 0;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.status-ongoing {
  background: #fff3e8;
  color: #ff7a00;
}

.status-success {
  background: #e8f7ee;
  color: #1f9d63;
}

.status-failed {
  background: #f1f2f5;
  color: #8f96a3;
}

.title-row,
.price-row,
.progress-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.course-title {
  flex: 1;
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2329;
  line-height: 1.5;
}

.group-chip,
.joined-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.group-chip {
  background: #eef5ff;
  color: #1677ff;
}

.joined-chip {
  background: #fff3e8;
  color: #ff7a00;
}

.price-row {
  align-items: flex-end;
  margin-top: 24rpx;
}

.group-price {
  color: #ff7a00;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.original-price {
  flex: 1;
  padding-bottom: 6rpx;
  color: #b6bdc8;
  font-size: 24rpx;
  text-decoration: line-through;
}

.info-list {
  margin-top: 28rpx;
}

.info-item + .info-item {
  margin-top: 18rpx;
}

.info-label {
  font-size: 24rpx;
  color: #8f96a3;
}

.info-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #1f2329;
  line-height: 1.7;
}

.progress-text,
.remaining-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2329;
}

.remaining-text {
  color: #5f6b7a;
}

.progress-track {
  width: 100%;
  height: 18rpx;
  margin-top: 20rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eef2f7;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1677ff 0%, #69a7ff 100%);
}

.progress-desc {
  margin-top: 18rpx;
}

.bottom-space {
  height: 160rpx;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(31, 35, 41, 0.06);
}

.bottom-button {
  width: 100%;
}

.bottom-status-text {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #5f6b7a;
}
