.detail-page {
  position: relative;
  min-height: 100vh;
  background: #f7f8fa;
}

.detail-scroll {
  height: 100vh;
}

.hero-swiper {
  width: 100%;
  height: 420rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.detail-content {
  margin-top: -20rpx;
  padding: 0 24rpx 0;
}

.title-row,
.price-row,
.group-progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.course-title {
  flex: 1;
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2329;
  line-height: 1.5;
}

.group-chip,
.joined-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.group-chip {
  background: #eef5ff;
  color: #1677ff;
}

.joined-chip {
  background: #fff3e8;
  color: #ff7a00;
}

.price-row {
  align-items: flex-end;
  margin-top: 24rpx;
}

.group-price {
  color: #ff7a00;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1;
}

.original-price {
  flex: 1;
  padding-bottom: 6rpx;
  color: #b6bdc8;
  font-size: 24rpx;
  text-decoration: line-through;
}

.info-list {
  margin-top: 28rpx;
}

.info-item + .info-item {
  margin-top: 18rpx;
}

.info-label {
  font-size: 24rpx;
  color: #8f96a3;
}

.info-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #1f2329;
  line-height: 1.7;
}

.rich-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #3c4655;
  line-height: 1.8;
}

.coach-name {
  margin-top: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

.coach-intro {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.8;
  color: #5f6b7a;
}

.certificate-list {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.certificate-image {
  width: 220rpx;
  height: 146rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: #eef2f7;
}

.insurance-card {
  background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
}

.insurance-text {
  margin-top: 16rpx;
  line-height: 1.8;
}

.group-panel,
.group-empty {
  margin-top: 20rpx;
}

.group-progress-text,
.group-remaining {
  font-size: 24rpx;
  color: #5f6b7a;
}

.progress-track {
  width: 100%;
  height: 16rpx;
  margin-top: 20rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #eef2f7;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #1677ff 0%, #69a7ff 100%);
}

.member-list {
  display: flex;
  margin-top: 24rpx;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  margin-right: -12rpx;
  border: 4rpx solid #ffffff;
  border-radius: 50%;
  background: #eef2f7;
}

.bottom-space {
  height: 160rpx;
}

.bottom-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -8rpx 24rpx rgba(31, 35, 41, 0.06);
}

.service-entry {
  width: 104rpx;
  text-align: center;
}

.service-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #eef5ff;
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 700;
}

.service-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #5f6b7a;
}

.bottom-action {
  flex: 1;
}

.service-modal-content {
  padding-top: 8rpx;
  text-align: center;
}

.service-qrcode {
  width: 240rpx;
  height: 240rpx;
  margin: 0 auto;
  border-radius: 20rpx;
  background: #eef2f7;
}

.service-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #5f6b7a;
}
