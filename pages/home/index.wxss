.home-page {
  padding-bottom: 40rpx;
}

.hero-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f3f8ff 100%);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2329;
}

.location-pill {
  display: flex;
  align-items: center;
  max-width: 320rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(22, 119, 255, 0.08);
}

.location-dot {
  width: 14rpx;
  height: 14rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #1677ff;
}

.location-text {
  overflow: hidden;
  color: #1677ff;
  font-size: 24rpx;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.tab-row {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.tab-item {
  min-width: 180rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: #eef2f7;
  color: #5f6b7a;
  text-align: center;
  font-size: 26rpx;
}

.tab-item-active {
  background: #1677ff;
  color: #ffffff;
  font-weight: 600;
}

.notice-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.notice-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.7;
  color: #5f6b7a;
}

.notice-action {
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 600;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.course-card {
  overflow: hidden;
  border-radius: 32rpx;
  background: #ffffff;
}

.cover-wrap {
  position: relative;
}

.course-cover {
  display: block;
  width: 100%;
  height: 280rpx;
  background: #eef2f7;
}

.group-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 122, 0, 0.92);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.course-content {
  padding: 28rpx;
}

.course-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.course-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #1f2329;
}

.distance-text {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #f5f7fb;
  color: #5f6b7a;
  font-size: 22rpx;
}

.course-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8f96a3;
}

.countdown-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #fff7ed 0%, #fff1df 100%);
}

.countdown-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ff7a00;
  box-shadow: 0 0 0 6rpx rgba(255, 122, 0, 0.12);
}

.countdown-text {
  color: #c96a10;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.course-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
}

.price-group {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
}

.group-price {
  color: #ff7a00;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
}

.original-price {
  padding-bottom: 4rpx;
  color: #b6bdc8;
  font-size: 24rpx;
  text-decoration: line-through;
}

.joined-text {
  color: #1677ff;
  font-size: 24rpx;
  font-weight: 600;
}

.list-footer {
  padding: 28rpx 0 16rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #8f96a3;
}
