.my-group-list-page {
  padding-bottom: 40rpx;
}

.tab-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: #ffffff;
  border-radius: 28rpx;
}

.tab-item {
  flex: 1;
  padding: 16rpx 0;
  border-radius: 999rpx;
  color: #5f6b7a;
  text-align: center;
  font-size: 24rpx;
}

.tab-item-active {
  background: #1677ff;
  color: #ffffff;
  font-weight: 600;
}

.group-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.group-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 28rpx;
}

.group-cover {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: #eef2f7;
}

.group-content {
  flex: 1;
  min-width: 0;
}

.group-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.status-group {
  display: flex;
  flex-shrink: 0;
  align-items: center;
  gap: 10rpx;
}

.group-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2329;
  line-height: 1.5;
}

.group-meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8f96a3;
}

.status-tag {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.status-ongoing {
  background: #e8f7ee;
  color: #1f9d63;
}

.status-success {
  background: #eef5ff;
  color: #1677ff;
}

.status-failed {
  background: #f1f2f5;
  color: #8f96a3;
}

.status-stage {
  background: #fff3e8;
  color: #ff7a00;
}

.list-footer {
  padding: 28rpx 0 16rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #8f96a3;
}
